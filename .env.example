# Server-only — set in Vercel dashboard and .env.local (never prefix with VITE_)
N8N_WEBOOK_URL=https://your-n8n-instance/webhook/your-id

# Optional: header sent to n8n when Header Auth is enabled on the webhook node
# N8N_WEBHOOK_SECRET=

# Optional: restrict CORS on /api/submit-lead for preview deploys
# ALLOWED_ORIGIN=https://yourdomain.com
